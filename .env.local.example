# Copy to .env.local and fill in values. .env.local is gitignored.

# --- Resend (transactional email) ---
# Reuse the same Resend account/API key as the tour-guide site.
# Get an API key at https://resend.com/api-keys (free tier: 100/day, 3k/month).
RESEND_API_KEY=re_**

# Sender. Until the new domain is verified in Resend, you MUST use the sandbox
# sender below — Resend will then only deliver to the Resend account owner email.
# Once the domain is verified, switch to e.g. "Cours de francais <contact@ton-domaine.com>".
CONTACT_FROM_EMAIL="Cours de francais <onboarding@resend.dev>"

# Recipient — where contact-form enquiries are sent.
# In sandbox mode, this MUST equal the email used to sign up for Resend.
CONTACT_TO_EMAIL=solene.lanza@gmail.com

# --- Cloudflare Turnstile (optional, anti-bot) ---
# Leave empty in dev to skip captcha verification.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- SEO ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
